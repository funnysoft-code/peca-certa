includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon
    - phar://phpstan.phar/conf/bleedingEdge.neon

parameters:

    paths:
        - app
        - bootstrap/app.php
        - config
        - database
        - public
        - routes

    # Uncomment when the --ts-transformer module is active:
    # The closure-heavy config/typescript-transformer.php chokes PHPStan at level max.
    excludePaths:
        # Spatie package migration is config-driven (mixed table/column names).
        - database/migrations/2026_07_23_115244_create_permission_tables.php
    #     - config/typescript-transformer.php

    level: max

    tmpDir: /tmp/phpstan
