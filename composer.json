{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/react-starter-kit",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "aws/aws-sdk-php": "^3.388",
        "inertiajs/inertia-laravel": "^3.0",
        "laravel/ai": "^0.7",
        "laravel/chisel": "^0.1.0",
        "laravel/fortify": "^1.36",
        "laravel/framework": "^13.0",
        "laravel/nightwatch": "^1.28",
        "laravel/octane": "^2.17",
        "laravel/reverb": "^1.10",
        "laravel/tinker": "^3.0",
        "laravel/wayfinder": "^0.1",
        "nunomaduro/essentials": "^1.2",
        "resend/resend-laravel": "^1.0",
        "spatie/laravel-permission": "^8.3",
        "spatie/laravel-query-builder": "^7.3"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.6",
        "driftingly/rector-laravel": "^2.3",
        "fakerphp/faker": "^1.24",
        "larastan/larastan": "^3.9",
        "laravel/boost": "^2.4",
        "laravel/pail": "^1.2",
        "laravel/pao": "^1.0",
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "pestphp/pest": "^5.0",
        "pestphp/pest-plugin-browser": "^5.0",
        "pestphp/pest-plugin-laravel": "^5.0",
        "pestphp/pest-plugin-type-coverage": "^5.0",
        "rector/rector": "^2.4",
        "roave/security-advisories": "dev-latest",
        "spatie/guidelines-skills": "^1.0",
        "spatie/laravel-typescript-transformer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "bun install",
            "bun run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "bunx concurrently -c \"#0ea5e9,#93c5fd,#fb7185,#fdba74,#a78bfa\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"php artisan reverb:start\" \"bun run dev\" --names=server,queue,logs,reverb,vite --kill-others"
        ],
        "lint": [
            "vendor/bin/rector --ansi",
            "vendor/bin/pint --parallel --ansi",
            "bun run lint"
        ],
        "test:type-coverage": "pest --type-coverage --min=100",
        "test:unit": "bin/coverage.sh --exactly=100.0 --exclude-testsuite=Browser",
        "test:lint": [
            "vendor/bin/pint --parallel --test --ansi",
            "vendor/bin/rector --dry-run --ansi",
            "bun run test:lint"
        ],
        "test:types": [
            "vendor/bin/phpstan analyse --memory-limit=2G --ansi",
            "bun run test:types"
        ],
        "test": [
            "@test:type-coverage",
            "@test:unit",
            "@test:lint",
            "@test:types"
        ],
        "ide": [
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:models --nowrite"
        ],
        "wayfinder": "@php artisan wayfinder:generate --with-form",
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [],
            "installer": {
                "post-create-project": []
            }
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
