# Product name — keep local .env in sync (do not commit secrets).
APP_NAME="R2CZ Auto Finder"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_PT
APP_FALLBACK_LOCALE=pt_PT
APP_FAKER_LOCALE=pt_PT

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Octane ---
OCTANE_SERVER=frankenphp

# --- Reverb (WebSockets) ---
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# --- Nightwatch (observability) ---
NIGHTWATCH_ENABLED=false
NIGHTWATCH_TOKEN=

# --- Laravel AI ---
AI_QUEUE=ai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
# default | priority — priority = lower latency, premium token rate
XAI_SERVICE_TIER=priority
AI_DEFAULT_PROVIDER=xai
# Optional: key-scoped console totals in `php artisan costs:update`
# console.x.ai → Settings → Management Keys + Team ID
# XAI_MANAGEMENT_KEY=
# XAI_TEAM_ID=
# XAI_API_KEY_ID=          # optional; auto-resolved via name or XAI_API_KEY suffix
# XAI_API_KEY_NAME=peca-certa
# XAI_BILLING_TIMEZONE=Europe/Lisbon

# --- Cost ledger (`php artisan costs:update`) ---
# COSTS_USD_EUR_RATE=0.92
# COSTS_PROJECT_START_MONTH=2026-07
# COSTS_LARAVEL_CLOUD_APP_ID=
# COSTS_CLOUDFLARE_ACCOUNT_ID=


# --- Suppliers ---
AUTODELTA_CATALOG_ID=
AUTODELTA_CATALOG_USER_ID=
AUTODELTA_USERNAME=
AUTODELTA_PASSWORD=
AUTOZITANIA_USERNAME=
AUTOZITANIA_PASSWORD=
# Local: leave empty (uses bun bin/zitania-search.ts). Production: Worker URL.
AUTOZITANIA_HTTP_URL=
AUTOZITANIA_HTTP_TOKEN=
# PartsLink24 — secrets / deploy only.
# Fingerprint, session, pacing, caches are HARDCODED in config/suppliers.php
# (live Chrome/150 Mac capture). See docs/partslink24/capture-2026-07-23-real-chrome.md
PARTSLINK24_ACCOUNT=
PARTSLINK24_USERNAME=
PARTSLINK24_PASSWORD=
# Optional shop egress proxy (HTTP/SOCKS). Empty = app host IP.
# PARTSLINK24_PROXY=http://user:pass@shop-proxy.local:3128
# BOM diagram storage. Production: PARTSLINK24_DIAGRAMS_DISK=s3
PARTSLINK24_DIAGRAMS_DISK=pl24_diagrams
# PL24_DIAGRAMS_DRIVER=local
# PL24_DIAGRAMS_ROOT=
